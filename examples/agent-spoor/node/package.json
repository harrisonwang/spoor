{
  "name": "spoor-agent-example-node",
  "private": true,
  "type": "module",
  "version": "0.1.0",
  "description": "把 spoor 接入一个最小编码 Agent 的三种方式：原生工具 / MCP Server / Skill（Node 实现）",
  "scripts": {
    "dev": "tsx --env-file=.env src/index.ts",
    "native": "tsx --env-file=.env src/index.ts --mode native",
    "mcp": "tsx --env-file=.env src/index.ts --mode mcp",
    "skill": "tsx --env-file=.env src/index.ts --mode skill",
    "mcp:server": "tsx src/mcp/spoor-server.ts",
    "type-check": "tsc --noEmit"
  },
  "dependencies": {
    "@harrisonwang/spoor": "^0.8.20",
    "@harrisonwang/spoor-cli": "^0.8.0",
    "@modelcontextprotocol/sdk": "^1.12.0",
    "openai": "^6.45.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "tsx": "^4.19.0",
    "typescript": "^5.6.0"
  }
}
