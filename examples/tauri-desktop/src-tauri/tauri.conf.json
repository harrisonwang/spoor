{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Spoor Document Desk",
  "version": "0.1.0",
  "identifier": "xyz.510006.spoor.tauri",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "Spoor Document Desk",
        "width": 1180,
        "height": 800,
        "minWidth": 760,
        "minHeight": 620
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": false
  }
}
